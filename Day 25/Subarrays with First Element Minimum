class Solution {
  public:
    int countSubarrays(vector<int> &arr) {
        int n = arr.size();
    stack<int> st;
    long long ans = 0;

    for (int i = 0; i < n; i++) {
        while (!st.empty() && arr[i] < arr[st.top()]) {
            int idx = st.top();
            st.pop();
            ans += i - idx;
        }
        st.push(i);
    }

    while (!st.empty()) {
        int idx = st.top();
        st.pop();
        ans += n - idx;
    }

    return ans;
        
    }
};
