class Solution {
  public:
    int countStrings(int n) {
        // code here
        if (n == 1) return 2;
        
        long long zero = 1; // dp[1][0]
        long long one = 1;  // dp[1][1]
        
        for (int i = 2; i <= n; i++) {
            long long newZero = zero + one;
            long long newOne = zero;
            
            zero = newZero;
            one = newOne;
        }
        
        return zero + one;
    }
};
