class Solution {
  public:
    int countIncreasing(vector<int>& arr) {
        long long ans = 0;
        long long len = 1;

        for (int i = 1; i < arr.size(); i++) {
            if (arr[i] > arr[i - 1]) {
                len++;
            } else {
                ans += (len * (len - 1)) / 2;
                len = 1;
            }
        }

        ans += (len * (len - 1)) / 2;
        return ans;
    }
};
