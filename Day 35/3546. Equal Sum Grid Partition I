class Solution {
public:
    bool canPartitionGrid(vector<vector<int>>& grid) {
        int m = grid.size();
        int n = grid[0].size();

        long long totalSum = 0;

        // Step 1: Calculate total sum
        for (auto &row : grid) {
            for (int val : row) {
                totalSum += val;
            }
        }

        // If total sum is odd → cannot split equally
        if (totalSum % 2 != 0) return false;

        long long target = totalSum / 2;

        // Step 2: Try horizontal cuts
        long long rowSum = 0;
        for (int i = 0; i < m - 1; i++) {
            for (int j = 0; j < n; j++) {
                rowSum += grid[i][j];
            }
            if (rowSum == target) return true;
        }

        // Step 3: Try vertical cuts
        vector<long long> colSum(n, 0);

        // Precompute column sums
        for (int j = 0; j < n; j++) {
            for (int i = 0; i < m; i++) {
                colSum[j] += grid[i][j];
            }
        }

        long long curr = 0;
        for (int j = 0; j < n - 1; j++) {
            curr += colSum[j];
            if (curr == target) return true;
        }

        return false;
    }
};
