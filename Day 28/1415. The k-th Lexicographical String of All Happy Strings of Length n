class Solution {
public:
    void generate(int n, int k, string &curr, vector<string> &res) {
        if (curr.size() == n) {
            res.push_back(curr);
            return;
        }

        for (char c : {'a','b','c'}) {
            if (!curr.empty() && curr.back() == c) continue;

            curr.push_back(c);
            generate(n, k, curr, res);
            curr.pop_back();

            if (res.size() >= k) return; // stop early
        }
    }

    string getHappyString(int n, int k) {
        vector<string> res;
        string curr = "";

        generate(n, k, curr, res);

        if (res.size() < k) return "";
        return res[k-1];
    }
};
