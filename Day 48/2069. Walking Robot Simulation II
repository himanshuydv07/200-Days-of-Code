class Robot {
public:
    int w, h, x, y, dir, perimeter;
    vector<string> d = {"East", "North", "West", "South"};
    
    Robot(int width, int height) {
        w = width;
        h = height;
        x = 0;
        y = 0;
        dir = 0;
        perimeter = 2 * (w + h) - 4;
    }
    
    void step(int num) {
        if (perimeter == 0) return;
        num %= perimeter;
        if (num == 0 && x == 0 && y == 0) dir = 3;

        while (num--) {
            int nx = x, ny = y;

            if (dir == 0) nx++;
            else if (dir == 1) ny++;
            else if (dir == 2) nx--;
            else ny--;

            if (nx < 0 || nx >= w || ny < 0 || ny >= h) {
                dir = (dir + 1) % 4;
                num++;
            } else {
                x = nx;
                y = ny;
            }
        }
    }
    
    vector<int> getPos() {
        return {x, y};
    }
    
    string getDir() {
        return d[dir];
    }
};

