class Solution {
public:
   bool match(const string &word, int i, const string &str2) {
    for (int j = 0; j < str2.size(); j++) {
        if (word[i + j] != str2[j]) return false;
    }
    return true;
}

string generateString(string str1, string str2) {
    int n = str1.size(), m = str2.size();
    int len = n + m - 1;

    string word(len, '?');

    // Step 1: Apply all 'T'
    for (int i = 0; i < n; i++) {
        if (str1[i] == 'T') {
            for (int j = 0; j < m; j++) {
                if (word[i + j] == '?' || word[i + j] == str2[j]) {
                    word[i + j] = str2[j];
                } else {
                    return "";
                }
            }
        }
    }

    // Step 2: Fill remaining with 'a'
    for (char &c : word) {
        if (c == '?') c = 'a';
    }

    // Step 3: Fix 'F'
    for (int i = 0; i < n; i++) {
        if (str1[i] == 'F') {
            if (match(word, i, str2)) {
                bool fixed = false;

                // Try to break match
                for (int j = m - 1; j >= 0 && !fixed; j--) {
                    int pos = i + j;
                    char original = word[pos];

                    for (char c = 'a'; c <= 'z'; c++) {
                        if (c == str2[j]) continue;

                        word[pos] = c;

                        // Check all 'T' constraints still hold
                        bool valid = true;
                        for (int k = 0; k < n; k++) {
                            if (str1[k] == 'T' && !match(word, k, str2)) {
                                valid = false;
                                break;
                            }
                        }

                        if (valid) {
                            fixed = true;
                            break;
                        }

                        word[pos] = original;
                    }
                }

                if (!fixed) return "";
            }
        }
    }

    // Step 4: FINAL VALIDATION (IMPORTANT FIX)
    for (int i = 0; i < n; i++) {
        if (str1[i] == 'T' && !match(word, i, str2)) return "";
        if (str1[i] == 'F' && match(word, i, str2)) return "";
    }

    return word;
}
};
